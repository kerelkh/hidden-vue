{
  "name": "hidden-vue",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Hidden Monitoring - Vue 3 desktop app with Electron",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/kerelkh/hidden-vue.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vue-tsc && vite build && electron-builder",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "swiper": "^12.1.3",
    "lucide-vue-next": "^0.468.0",
    "@vueuse/core": "^12.8.2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0",
    "update-electron-app": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.2.2",
    "vue-tsc": "^2.2.4",
    "vite": "^8.0.0",
    "@tailwindcss/vite": "^4.1.11",
    "tailwindcss": "^4.1.1",
    "tw-animate-css": "^1.2.5",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kerel.hidden-monitoring",
    "productName": "HiddenMonitoring",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "kerelkh",
      "repo": "hidden-vue"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/favicon.svg"
    }
  }
}